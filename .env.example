# URLs dos serviços internos
AUTH_SERVICE_URL=http://auth-service:8000
AUTH_BROWSER_URL=http://localhost:8001
AUTH_SSO_CLIENT_ID=flash-sale
INVENTORY_SERVICE_URL=http://inventory-service:8000
PAYMENT_SERVICE_URL=http://payment-service:8000

# Credencial interna para chamadas service-to-service ao Auth (/api/v1/auth/verify)
INTERNAL_SERVICE_KEY=internal-dev-key-2024

# API Keys para autenticação serviço-a-serviço
INVENTORY_API_KEY=sk_test_inventory_dev_key

# Chave usada pelo Composer para chamar o Payment Service.
# Ideal: tenant key criada via POST /api/v1/admin/api-keys.
PAYMENT_API_KEY=admin-dev-key-2024

# Chave admin do Payment Service (bootstrap para gerir tenant keys)
PAYMENT_ADMIN_API_KEY=admin-dev-key-2024

# Política de mutações de eventos no Composer
# false = compatibilidade (não exige role)
# true  = exige role autorizada no token do utilizador
EVENT_MUTATIONS_REQUIRE_ADMIN=true

# Roles permitidas para criar/editar/apagar eventos e criar tickets
EVENT_ADMIN_ROLES=admin,promoter
