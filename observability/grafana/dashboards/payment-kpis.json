{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Payment Volume (per chart bucket)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (currency) (increase(payment_service_payment_amount_cents_total[$__interval])) / 100",
          "legendFormat": "{{currency}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Payment Outcomes (per chart bucket)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (status) (increase(payment_service_payment_transactions_total{status=~\"succeeded|failed|canceled\"}[$__interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Payment Success Rate (overall)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "green", "value": 98 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "expr": "100 * sum(payment_service_payment_transactions_total{status=\"succeeded\"}) / clamp_min(sum(payment_service_payment_transactions_total{status=~\"succeeded|failed|canceled\"}), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Checkout Conversion (overall)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "expr": "100 * sum(payment_service_checkout_sessions_total{status=\"complete\"}) / clamp_min(sum(payment_service_checkout_sessions_total{status=\"created\"}), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Refunds Issued (selected range)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(payment_service_payment_refunds_total[$__range])) or on() vector(0)",
          "legendFormat": "Refunds",
          "refId": "A"
        }
      ]
    },
    {
      "title": "New Customers (selected range)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(payment_service_customers_registered_total[$__range])) or on() vector(0)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(payment_service_http_server_duration_milliseconds_bucket[5m])) by (le)) / 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(payment_service_http_server_duration_milliseconds_bucket[5m])) by (le)) / 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(payment_service_http_server_duration_milliseconds_bucket[5m])) by (le)) / 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "EGS Auth Avg Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(payment_service_auth_service_request_duration_seconds_sum[$__rate_interval])) / clamp_min(sum(rate(payment_service_auth_service_request_duration_seconds_count[$__rate_interval])), 1e-9)",
          "legendFormat": "avg",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Errors (per chart bucket)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(payment_service_http_server_duration_milliseconds_count{http_status_code=~\"4..\"}[$__interval])) or on() vector(0)",
          "legendFormat": "4xx",
          "refId": "A"
        },
        {
          "expr": "sum(increase(payment_service_http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[$__interval])) or on() vector(0)",
          "legendFormat": "5xx",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Rate Limit Rejections (per chart bucket)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(payment_service_rate_limit_exceeded_total[$__interval])) or on() vector(0)",
          "legendFormat": "Rate Limited",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["payment-service", "kpi"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Payment Service KPIs",
  "uid": "payment-service-kpis",
  "version": 1
}
