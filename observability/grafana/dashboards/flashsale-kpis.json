      "type": "table",
      "description": "Cumulative Composer proxy calls since the current Composer pod started, grouped by service, HTTP method, endpoint path, and status class.",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "service": 0,
              "method": 1,
              "path": 2,
              "status_class": 3,
              "Value": 4
            },
            "renameByName": {
              "service": "Service",
              "method": "Method",
              "path": "Endpoint",
              "status_class": "Status",
              "Value": "Calls"
            }
          }
        }
